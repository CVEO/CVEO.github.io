---
import { Image } from 'astro:assets';

interface Props {
  src: string;
  alt: string;
  aspectRatio?: string;
  className?: string;
  lazy?: boolean;
  fallbackSrc?: string;
  width?: number;
  height?: number;
}

const { 
  src, 
  alt, 
  aspectRatio = "1/1", 
  className = "", 
  lazy = true,
  fallbackSrc = "/assets/avatars/placeholder.svg",
  width = 400,
  height = 400
} = Astro.props;

const aspectRatioClass = {
  "3/4": "aspect-[3/4]",
  "1/1": "aspect-square",
  "4/3": "aspect-[4/3]",
  "16/9": "aspect-video"
}[aspectRatio] || "aspect-square";

const handleError = `
  this.onerror = null;
  this.src = '${fallbackSrc}';
`;
---

<img 
  src={src} 
  alt={alt}
  width={width}
  height={height}
  class={`object-cover rounded ${aspectRatioClass} ${className}`}
  loading={lazy ? "lazy" : "eager"}
  decoding={lazy ? "async" : "auto"}
  onerror={handleError}
/>
